<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TaskApp.Core.ViewModels;assembly=TaskApp.Core"
             x:Class="TaskApp.Maui.Views.TaskEditPage"
             x:DataType="vm:TaskEditViewModel"
             Title="Editar tarefa"
             BackgroundColor="{StaticResource Surface}">

    <VerticalStackLayout Padding="16" Spacing="16">

        <Label Text="Título" FontSize="13" Opacity="0.7" />
        <Entry Text="{Binding Title}" Placeholder="Título da tarefa" />

        <Grid ColumnDefinitions="*,Auto">
            <Label Grid.Column="0" Text="Concluída" VerticalOptions="Center" />
            <Switch Grid.Column="1" IsToggled="{Binding IsCompleted}" />
        </Grid>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,16,0,0">
            <Button Grid.Column="0" Text="Cancelar"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource OnSurface}" />
            <Button Grid.Column="1" Text="Salvar"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
        </Grid>
    </VerticalStackLayout>
</ContentPage>
